# These values are baked into docker-compose.yml and used by the backend's .env file.
POSTGRES_USER=cloudtutor
POSTGRES_PASSWORD=cloudtutor
POSTGRES_DB=cloudtutor
POSTGRES_PORT=5432

# Construct the DATABASE_URL the backend expects:
# DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:${POSTGRES_PORT}/${POSTGRES_DB}
